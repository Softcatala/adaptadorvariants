# - Sphinx -

# Remove XML entities.
# include file="filter.include"

# Remove accelerators inside words.
addFilterRegex match="&" on="pmsgid,pmsgstr"

{(\b|>)\`_}
valid msgstr="(\b|>)\`_"
hint="Segurament manca un enllaç «(NOTA: no funciona en alguns enllaços. Els que s'han canviat...)» (Sphinx)."

{\s\`}
id="t-acc_obe"
valid msgid="(^|\s)\`\`"
valid msgid="\b32 bits Intel CPU APK\b"
valid msgstr="\bKRITA_DEBUG_TEXTTOOL\b"
valid msgstr="\\ \`\[[123]\]"
valid msgstr="\'\`\`"
valid msgstr="(^|\s)\`([«<]|\b)"
valid msgstr="\'\`(«|\[|\b)"
hint="Segurament s'ha d'eliminar l'espai anterior o manca un enllaç (Sphinx)."

