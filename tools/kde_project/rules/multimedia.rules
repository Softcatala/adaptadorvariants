# La gamma ajusta la manera com es distribueix la lluminositat (contrast) a la imatge, especialment en els tons mitjos, per adaptar-la a com veu l'ull humà.
# Gamma - LLUM - La brillantor dels tons mitjos i el contrast. - Fer les ombres més clares o fosques.
# Gamut = Quants colors tinc a la paleta?
{\bgamma\b}i
valid msgid="\bauto.?gamma\b"
valid msgid="\bBrightness/Contrast/Gamma\b"
valid msgid="\bgamma.?(compression|correct(ed|ion)|curve|dark|encoding|ramp|transfer\scurve|transform)\b"
valid msgid="\b(linear|usual)\sgamma\b"
valid msgstr="\bgamma\b"
hint="Es tradueix per «gamma» (multimèdia)."

  {\bauto.?gamma\b}i
  valid msgstr="\bgamma automàtica\b"
  hint="Es tradueix per «gamma automàtica» (multimèdia)."

  {\bBrightness/Contrast/Gamma\b}i
  valid msgstr="\bBrillantor/Contrast/Gamma\b"
  hint="Es tradueix per «(Eina:) Brillantor/Contrast/Gamma» (multimèdia)."

  {\bgamma.?compression\b}i
  valid msgstr="\bcompressió de gamma\b"
  hint="Es tradueix per «compressió de gamma» (multimèdia)."

  {\bgamma.?correct(ed|ion)\b}i
  valid msgid="\bnon.?linear\sgamma\scorrection\b"
  valid msgstr="\bcorre(cció de|geix|gida per) la gamma\b"
  hint="Es tradueix per «correcció de la gamma, corregida per la gamma, corregeix la gamma» (multimèdia)."

    {\bnon.?linear\sgamma\scorrection\b}i
    valid msgstr="\bcorrecció de l'interval no lineal\b"
    hint="Es tradueix per «correcció de l'interval no lineal» (multimèdia)."

  {\bgamma.?curve\b}i
  valid msgid="\bhybrid\slog\sgamma.?curve\b"
  valid msgstr="\bcorba amb interval\b"
  hint="Es tradueix per «corba amb interval» (multimèdia)."

  {\bgamma\sdark\b}i
  valid msgstr="\bgamma fosca\b"
  hint="Es tradueix per «gamma fosca» (multimèdia)."

  {\bgamma.?encoding\b}i
  valid msgstr="\bcodificació de gamma\b"
  hint="Es tradueix per «codificació de gamma» (multimèdia)."

  {\bgamma.?ramp\b}i
  valid msgstr="\bdesnivell de gamma\b"
  hint="Es tradueix per «desnivell de gamma» (multimèdia)."

  {\bgamma\stransfer\scurve\b}i
  valid msgstr="\bcorba de transferència de la gamma\b"
  hint="Es tradueix per «corba de transferència de la gamma» (multimèdia)."

  {\bgamma\stransform\b}i
  valid msgstr="\btransformació de gamma\b"
  hint="Es tradueix per «transformació de gamma» (multimèdia)."

  {\bhybrid\slog\sgamma.?curve\b}i
  valid msgstr="\bcorba amb interval de registres híbrid\b"
  hint="Es tradueix per «corba amb interval de registres híbrid» (multimèdia)."

  {\blinear\sgamma\b}i
  valid msgid="\blinear\sgamma\scurve\b"
  valid msgid="\bnon?.?linear\sgamma\b"
  valid msgstr="\binterval lineal\b"
  hint="Es tradueix per «interval lineal» (multimèdia)."

    {\blinear\sgamma\scurve\b}i
    valid msgstr="\bcorba amb interval lineal\b"
    hint="Es tradueix per «corba amb interval lineal» (multimèdia)."

    {\bnon?.?linear\sgamma\b}i
    valid msgstr="\binterval no lineal\b"
    hint="Es tradueix per «interval no lineal» (multimèdia)."

  {\busual\sgamma\b}i
  valid msgstr="\binterval de costum\b"
  hint="Es tradueix per «interval de costum» (multimèdia)."

# El gamut és el conjunt limitat de colors que un dispositiu (càmera, monitor, impressora) pot captar, mostrar o reproduir.
# Gamut - COLOR - La quantitat i saturació de matisos. - Adobe RGB versus sRGB.
# Gamma = Com de clara o fosca vull la meva paleta?
{\bgamut\b}i
valid msgid="\b(color|expanded|large|medium|out.?of|small|wide).?gamut\b"
valid msgid="\bgamut.?(clipping|large|masks?)\b"
valid msgstr="\bgamut\b"
hint="Es tradueix per «gamut (en femení: gamut de colors, espectre de color, espai de color -segons el context-» (multimèdia)."

  {\bcolor.?gamut\b}i
  valid msgid="\bsmall\scolor.?gamut\b"
  valid msgstr="\bgamut de colors\b"
  hint="Es tradueix per «gamut de colors (en femení)» (multimèdia)."

    {\bsmall\scolor.?gamut\b}i
    valid msgstr="\bgamma (petita|xicoteta) de colors\b"
    hint="Es tradueix per «gamma petita de colors (en femení)» (multimèdia)."

  {\bexpanded.?gamut\b}i
  valid msgstr="\bgamut expandit\b"
  hint="Es tradueix per «gamut expandit (en femení)» (multimèdia)."

  {\bgamut.?clipping\b}i
  valid msgstr="\bretallada de la gamut\b"
  hint="Es tradueix per «retallada de la gamut (en femení)» (multimèdia)."

  {\bgamuts\b}i
  valid msgid="\b(wide\s)?color\sgamuts\b"
  valid msgid="\bwide.?gamuts\b"
  valid msgstr="\bgamuts\b"
  hint="Es tradueix per «gamuts (en femení)» (multimèdia)."

    {\bcolor.?gamuts\b}i
    valid msgid="\bwide\scolor\sgamuts\b"
    valid msgstr="\bgamuts de colors\b"
    hint="Es tradueix per «gamuts de colors (en femení)» (multimèdia)."

  {\blarge.?gamut\b}i
