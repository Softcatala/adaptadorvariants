# - multimèdia -

# Remove XML entities.
# include file="filter.include"

# Remove accelerators inside words.
addFilterRegex match="&" on="pmsgid,pmsgstr"

{\b\*\*\ssetting\b}i
valid msgstr="\bparàmetre \*\*\b"
valid msgstr="\bparàmetre d'\*\*\b"
valid msgstr="\bparàmetre de \*\*\b"
hint="Es tradueix per «paràmetre **» (multimèdia)."

{\bAdobe\sRGB\b}i
valid msgstr="\bAdobe RGB\b"
hint="Es tradueix per «Adobe RGB (un espai de color)» (multimèdia)."

