# - general -

# Remove XML entities.
# include file="filter.include"

# Remove accelerators inside words.
addFilterRegex match="&" on="pmsgid,pmsgstr"

## varis ##
###########
  {\(Bright\)}
  valid msgstr="\(animat\)"
  hint="Es tradueix per «(animat)»."

  {\(Long\)}
  valid msgstr="\(llarg\)"
  hint="Es tradueix per «(llarg)»."

  {\(Medium\)}
  valid msgstr="\(mitj(à|ana)\)"
  hint="Es tradueix per «(mitjà(ana))»."

  {\(Small\)}
  valid msgstr="\(xicoteta\)"
  hint="Es tradueix per «(xicoteta)»."

  {\(Thick\)}
  valid msgstr="\(dens\)"
  hint="Es tradueix per «(dens)»."

{(\bShift;|(\*\*|<key(cap|sym)?>).?Shift.?(</key(cap|sym)?>|\*\*))}
id="k-Shift-2"
valid msgstr="(\*\*|<key(cap)?>)Majús(</key(cap)?>|\*\*)"
hint="Es tradueix per «&Maj;», «<key>Maj</key>(Gnome)/<keycap>Maj</keycap>(KDE)», «**Majús**» (keys)"

# Space -> Espai
{(\bSpace;|(\*\*|<key(cap|sym)?>).?Space(\s?-?bar)?.?(</key(cap|sym)?>|\*\*))}
id="k-Space"
valid msgstr="\bSpace;" # <keysym>Majús.</keysym>
valid msgstr="(\*\*|<key(cap|sym)?>)Espai(</key(cap|sym)?>|\*\*)"
hint="Es tradueix per «&Space;», «<key>Espai</key>(Gnome)/<keysym>Espai</keysym>(KDE)», «**Espai**» (keys)"

# Start -> Inici
{(\*\*|<key(cap|sym)?>).?Start.?(</key(cap|sym)?>|\*\*)}
id="k-Start"
valid msgstr="(\*\*|<key(cap)?>)Inicia?(</key(cap)?>|\*\*)"
hint="Es tradueix per «<key>Inici</key>(Gnome)/<keycap>Inici</keycap>(KDE)», «**Inici/a**» (keys)"

# Cursor keys
# Down Arrow -> Fletxa avall
{(\bDown;|(\*\*|<key(cap|sym)?>).?Down(\sArrow)?.?(</key(cap|sym)?>|\*\*))}
id="k-DownArrow"
valid msgstr="\bDown;" # <keysym>Fletxa avall</keysym>
valid msgstr="(\*\*|<key(cap|sym)?>)Fletxa avall(</key(cap|sym)?>|\*\*)"
hint="Es tradueix per «&Down;», «<key>Fletxa avall</key>(Gnome)/<keysym>Fletxa avall</keysym>(KDE)», «**Fletxa avall**» (keys)"

# Up Arrow -> Fletxa amunt
{(\bUp;|(\*\*|<key(cap|sym)?>).?Up(\sArrow)?.?(</key(cap|sym)?>|\*\*))}
id="k-UpArrow"
valid msgstr="\bUp;" # <keysym>Fletxa amunt</keysym>
valid msgstr="(\*\*|<key(cap|sym)?>)Fletxa amunt(</key(cap|sym)?>|\*\*)"
hint="Es tradueix per «&Up;», «<key>Fletxa amunt</key>(Gnome)/<keysym>Fletxa amunt</keysym>(KDE)», «**Fletxa amunt**» (keys)"

# Left Arrow -> Fletxa esquerra
{(\bLeft;|(\*\*|<key(cap|sym)?>).?Left(\sArrow)?.?(</key(cap|sym)?>|\*\*))}
id="k-LeftArrow"
valid msgstr="\bLeft;" # <keysym>Fletxa esquerra</keysym>
valid msgstr="(\*\*|<key(cap|sym)?>)Fletxa esquerra(</key(cap|sym)?>|\*\*)"
hint="Es tradueix per «&Left;», «<key>Fletxa esquerra</key>(Gnome)/<keysym>Fletxa esquerra</keysym>(KDE)», «**Fletxa esquerra**» (keys)"

# Right Arrow -> Fletxa dreta
{(\bRight;|(\*\*|<key(cap|sym)?>).?Right(.?Arrow)?(\s)?(</key(cap|sym)?>|\*\*))}
id="k-RightArrow"
valid msgid="(\*\*|)Rights(|\*\*) tab" # digikam-doc/docs_digikam_org_setup_application___templates_settings.po
valid msgstr="\bRight;" # <keysym>Fletxa dreta</keysym>
valid msgstr="(\*\*|<key(cap|sym)?>)Fletxa dreta(</key(cap|sym)?>|\*\*)"
hint="Es tradueix per «&Right;», «<key>Fletxa dreta</key>(Gnome)/<keysym>Fletxa dreta</keysym>(KDE)», «**Fletxa dreta**» (keys)"

{(\*\*|\b)Rights(\b|\*\*)}i
valid msgid="\b(game\smaster|human|patent|trademark)\srights\b"
valid msgid="\brights\sin\sthe\spatents\b"
valid msgid="(\*\*|)Rights(|\*\*) tab\b"
valid msgstr="(«|\*\*)Drets(\*\*|»)"
valid msgstr="^drets(:|)$"
valid msgstr="\ball rights reserved\b"
valid msgstr="\bdrets (d'accés|d'administració|d'administrador|del document|legals|segons)\b"  # documentation-kstars-docs-kde-org/kstars_docs_user_manual___gpl-3.0.po
valid msgstr="\bLlicència/Drets:"
valid msgstr="\bpermisos (a l'ordinador|d'accés|d'administrador|de lectura|necessaris)\b"
valid msgstr="\b(dels|els|necessiten|seus|vostres) drets\b" # digikam-doc/docs_digikam_org_getting_started___introduction.po
hint="Es tradueix per « «Drets», **Drets**»"

  {\bgame\smaster\srights\b}i
  valid msgstr="\bdrets de director de joc\b"
  hint="Es tradueix per «drets de director de joc»"

  {\bhuman\srights\b}i
  valid msgstr="\bdrets humans\b"
  hint="Es tradueix per «drets humans»"

  {\bpatent\srights\b}i
  valid msgstr="\bdrets? de patents?\b"
  hint="Es tradueix per «dret/s de patent/s»"

  {\brights\sin\sthe\spatents\b}i
  valid msgstr="\bdret (a|en) la patent\b"
  hint="Es tradueix per «dret a la patent»"

  {(\*\*|)Rights(|\*\*)\stab\b}i
  valid msgstr="\bpestanya («|\*\*)Drets(\*\*|»)"
  hint="Es tradueix per «pestanya «Drets», pestanya **Drets**»"

  {\btrademark\srights\b}i
  valid msgstr="\bdret de marca comercial\b"
  valid msgstr="\bdrets de marca registrada\b"
  hint="Es tradueix per «dret de marca comercial, drets de marca registrada»"

{-?->}
valid msgid=":menuselection:"
valid msgid="-->\n"
valid msgid="[})!]-->"
valid msgid="\.-->"
valid msgstr="→"
hint="Es tradueix per « → »."

[-?->]
valid msgstr=":menuselection:"
valid msgstr="[})!]-->"
valid msgstr="\.-->"
valid msgstr="-->\n"
valid msgstr="→"
hint="Es tradueix per « → »."

{ - }
valid msgstr="\b.?:?\*\*:? "
valid msgstr="\b.?: "
valid msgstr="\(opcional,"
valid msgstr="«-»"
valid msgstr="\bfins a l'\b"
valid msgstr="\bfins al\b"
valid msgstr="«–»"
valid msgstr=" -\b\w"
valid msgstr=" – "
hint="Es tradueix per « – »."

[ - ]
valid msgstr=" – "
hint="Es tradueix per « – »."

{\.\.\.}i
valid msgid="\s\.\.\.( |)etc\b"
valid msgid="\.\.\.\?b"
valid msgid="\.\.\. etc\b"
valid msgid=",\s\.\.\."
valid msgid="%2\s\.\.\.\s%3"
valid msgid="0\.\.\.5"
valid msgid="\bbut\.\.\.\show\b"
valid msgid="\betc\.\.\."
valid msgid="\btarget\sremote\s\.\.\."
valid msgstr="«ignoreHighFunctionKeys=false»" # websites-kde-org/news.po
valid msgstr="\bSabíeu que[?]"
valid msgstr="…"
hint="Se substitueix per «…»."

  [, \.\.\.]
  valid msgstr=", etc\."
  hint="Se substitueix per «, etc.»."

