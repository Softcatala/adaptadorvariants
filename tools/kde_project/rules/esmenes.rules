#
#

# Remove XML entities.
# include file="filter.include"

# Remove accelerator and  hyphen inside words.
addFilterRegex match="(_|~|&)" on="pmsgid,pmsgstr"

# {\b\b}i
# valid msgstr=""
# hint="«» es tradueix per «»."

# Enfoca cap
# Orienta cap
# bind -> vincular
# Setup Tab -> Logs

# statusTip
# label, entry
# i18n: ectx: property (text
# [([!@#>\\$%\\^\\&*\\)\\('+=·._-]|[0123456789%àçéèíïóòúüa-zA-Z])|((<[^<]{1,}>)+\n)?((<[^<]{1,}>)+\n)?(<[^<]{1,}>|)+$]
# id="punt-final"
# valid !comment="i18n: ectx: ((toolTip|whatsthis)|(attribute|property) \((toolTip|whatsThis)).*"
# valid msgstr="([.!?]\)|[.!?])((<[^<]{1,}>)+\n)?((<[^<]{1,}>)+\n)?(<[^<]{1,}>|)+$"
# hint="S'hauria d'emprar un signe de puntuacio final. Afegiu la nota « skip-rule: punctuation-period-no »."
#
# [([!@#>\\$%\\^\\&*\\)\\('+=·._-]|[0123456789%àçéèíïóòúüa-zA-Z])|((<[^<]{1,}>)+\n)?((<[^<]{1,}>)+\n)?(<[^<]{1,}>|)+$]
# id="toolTip"
# valid !comment="i18n: ectx: (toolTip|(attribute|property) \(toolTip).*"
# hint="toolTip: S'ha d'indicar què fa l'acció o quina s'ha de fer."
#
# [([!@#>\\$%\\^\\&*\\)\\('+=·._-]|[0123456789%àçéèíïóòúüa-zA-Z])|((<[^<]{1,}>)+\n)?((<[^<]{1,}>)+\n)?(<[^<]{1,}>|)+$]
# id="whatsthis"
# valid !comment="i18n: ectx: (whatsthis|(attribute|property) \(whatsThis).*"
# hint="whatsThis: S'ha d'indicar què fa l'accio o quina s'ha de fer."

# i18n: ectx: property (title)
# i18n: ectx: property (windowTitle)
# @title:window

# i18n: ectx: property (placeholderText)

{\bdirectory\b}i
valid msgid="-directory-"
valid msgid="\bActive Directory\b"
valid msgstr="\bhome\sdirectory\b"
valid msgstr="\bsub.?directory\b"
valid msgstr="\bcarpeta\b"
hint="Es tradueix per «carpeta» (multimèdia)."

  {\bhome\sdirectory\b}i
  valid msgstr="\bcarpeta d'inici\b"
  hint="Es tradueix per «carpeta d'inici» (multimèdia)."

  {\bsub.?directory\b}i
  valid msgstr="\bsubcarpeta\b"
  hint="Es tradueix per «subcarpeta» (multimèdia)."

{\bdirectorys\b}i
valid msgstr="\bsub.?directorys\b"
valid msgstr="\bcarpetes\b"
hint="Es tradueix per «carpetes» (multimèdia)."

  {\bsub.?directorys\b}i
  valid msgstr="\bsubcarpetes\b"
  hint="Es tradueix per «subcarpetes» (multimèdia)."

[\bdirectori\b]i
valid msgstr="\bcarpeta\b"
hint="Es tradueix per «carpeta»."

  [\bdirectoris\b]i
  valid msgstr="\bdirectoris\smundials\b"
  valid msgstr="\bcarpetes\b"
  hint="Es tradueix per «carpetes»."

  [\bsubdirectori\b]i
  valid msgstr="\bsubcarpeta\b"
  hint="Es tradueix per «subcarpeta»."

  [\bsubdirectoris\b]i
  valid msgstr="\bsubcarpetes\b"
  hint="Es tradueix per «subcarpetes»."

[\bestablits?\b]i
hint="Es traduix per «establert(s)»."

